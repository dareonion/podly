<?xml version="1.0" encoding="utf-8"?>
<!-- Auto-backup rules for API 29-30 (see data_extraction_rules.xml for 31+).
     The settings DataStore holds API keys in plaintext, so it stays out of
     cloud backups; downloaded audio is large and re-downloadable. -->
<full-backup-content>
    <exclude domain="file" path="datastore/settings.preferences_pb" />
    <exclude domain="file" path="episodes" />
</full-backup-content>
