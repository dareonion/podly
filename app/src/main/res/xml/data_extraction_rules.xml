<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup rules. Cloud backup must not carry the plaintext API keys
     (settings DataStore) or bulky downloaded audio. Direct device-to-device
     transfer keeps settings so a new phone keeps its keys. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="file" path="episodes" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="episodes" />
    </device-transfer>
</data-extraction-rules>
